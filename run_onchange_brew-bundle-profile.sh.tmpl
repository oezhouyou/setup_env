#!/bin/bash
# Runs brew bundle for the profile-specific Brewfile when it changes.
# {{ include (printf "Brewfile.%s" .profile) | sha256sum }}

PROFILE_BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile.{{ .profile }}"

if [ -f "$PROFILE_BREWFILE" ]; then
  brew bundle --file="$PROFILE_BREWFILE" || true
fi
