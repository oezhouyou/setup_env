# Admin work-machine install - shared packages/apps only.
# Run Brewfile.user after this for the admin user's per-user tools.

# CLI tools
brew "node"
brew "uv"
brew "neonctl"
brew "gh"
brew "ripgrep"
brew "fzf"
brew "bat"
brew "eza"
brew "fd"
brew "jq"
brew "delta"
brew "lazygit"
brew "htop"
brew "pandoc"
cask "basictex"

# Apps
cask "iterm2"
cask "brave-browser"
cask "cursor"
cask "claude"
cask "slack"
cask "zoom"
cask "notion"
cask "microsoft-teams"
cask "fathom"
cask "granola"
cask "linearmouse"
cask "docker-desktop"
cask "ollama-app"
cask "raycast"
cask "tableplus"
cask "proxyman"
